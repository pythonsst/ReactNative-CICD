{
  "cli": {
    "version": ">= 16.32.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "distribution": "store",
      "environment": "development",
      "env": {
        "ENVFILE": ".env.development"
      },
      "autoIncrement": true,
      "android": {
        "gradleCommand": ":app:bundleDevelopmentRelease"
      },
      "ios": {
        "scheme": "ReactNativeCICD development"
      }
    },
    "staging": {
      "distribution": "store",
      "environment": "preview",
      "env": {
        "ENVFILE": ".env.staging"
      },
      "autoIncrement": true,
      "android": {
        "gradleCommand": ":app:bundleStagingRelease"
      },
      "ios": {
        "scheme": "ReactNativeCICD staging"
      }
    },
    "production": {
      "distribution": "store",
      "environment": "production",
      "env": {
        "ENVFILE": ".env.production"
      },
      "autoIncrement": true,
      "android": {
        "gradleCommand": ":app:bundleProductionRelease"
      },
      "ios": {
        "scheme": "ReactNativeCICD production"
      }
    }
  },
  "submit": {
    "development": {
      "android": {
        "applicationId": "com.shivshankartiwari.reactnativeignitekit",
        "track": "internal",
        "releaseStatus": "draft"
      },
      "ios": {
        "ascAppId": "YOUR_APP_STORE_APP_ID"
      }
    },
    "staging": {
      "android": {
        "applicationId": "com.shivshankartiwari.reactnativeignitekit",
        "track": "beta",
        "releaseStatus": "draft"
      },
      "ios": {
        "ascAppId": "YOUR_APP_STORE_APP_ID"
      }
    },
    "production": {
      "android": {
        "applicationId": "com.shivshankartiwari.reactnativeignitekit",
        "track": "production",
        "releaseStatus": "completed"
      },
      "ios": {
        "ascAppId": "YOUR_APP_STORE_APP_ID"
      }
    }
  }
}
